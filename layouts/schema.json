{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["eventId", "name", "sections"],
  "properties": {
    "eventId": { "type": "string" },
    "name": { "type": "string" },
    "branding": {
      "type": "object",
      "properties": {
        "logo": { "type": "string" },
        "primaryColor": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tables"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "tables": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "row", "col", "seats"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "row": { "type": "integer", "minimum": 0 },
                "col": { "type": "integer", "minimum": 0 },
                "seats": { "type": "integer", "minimum": 1, "maximum": 12 }
              }
            }
          }
        }
      }
    }
  }
}
